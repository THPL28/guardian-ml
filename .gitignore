# Guardian-ML .gitignore

# ============================================================================
# ENVIRONMENT & CONFIGURATION
# ============================================================================
.env
.env.local
.env.*.local
.venv/
venv/
env/
ENV/
*.egg-info/

# ============================================================================
# DATA FILES
# ============================================================================
data/raw/
data/processed/
data/feature_store/
*.parquet
*.csv
*.feather

# ============================================================================
# MODELS & ARTIFACTS
# ============================================================================
models/*/
*.pkl
*.joblib
*.h5
*.pt
*.pth
mlruns/
mlflow.db

# ============================================================================
# NOTEBOOKS & JUPYTER
# ============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints
*/.ipynb_checkpoints/*
.jupyter/

# ============================================================================
# LOGS & MONITORING
# ============================================================================
logs/
*.log
events.out.tfevents.*

# ============================================================================
# CACHE & TEMPORARY
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
.cache/
.pytest_cache/
*.tmp
*.temp

# ============================================================================
# IDE & EDITOR
# ============================================================================
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# TESTING
# ============================================================================
.coverage
htmlcov/
.tox/
dist/
build/

# ============================================================================
# CREDENTIALS & SECRETS
# ============================================================================
secrets.json
config.secrets.yaml
credentials/
*.pem
*.key
*.p12

# ============================================================================
# DOCUMENTATION BUILD
# ============================================================================
docs/_build/
docs/.build/
site/

# ============================================================================
# INTERVIEW PREPARATION FILES (keep private, not for GitHub)
# ============================================================================
docs/INTERVIEW_PREPARATION.md
docs/EXECUTIVE_SUMMARY.md
docs/SUMMARY.md

# ============================================================================
# LARGE FILES (if untracked)
# ============================================================================
*.tar.gz
*.zip
*.rar

# ============================================================================
# AWS / Cloud
# ============================================================================
.aws/
.gce/
.azure/

# ============================================================================
# MAC
# ============================================================================
.DS_Store
.AppleDouble
.LSOverride

# Keep these (important project files)
!.gitkeep
!requirements.txt
!config/*.yaml
!README.md
